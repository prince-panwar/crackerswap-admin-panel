# Base URL of the CrackerSwap backend admin API (includes the /v1 prefix).
# MUST be https:// for any non-local deployment — the app refuses to build a
# request URL from an unset value in production, and http would transmit the
# access token in cleartext. Local dev default shown below.
VITE_API_BASE_URL=http://localhost:8000/v1

# Optional: expose the Vite dev server on the LAN (default binds to localhost).
# VITE_DEV_HOST=0.0.0.0
